{
  "info": {
    "name": "Proyecto Final Clinico - SuperUser API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección de Postman para los endpoints de SuperUser y FHIR."
  },
  "item": [
    {
      "name": "SuperUser Login",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"medico@example.com\",\n  \"password\": \"SuperPass2026\",\n  \"license_number\": \"MED123456\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/superuser/login",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "superuser", "login"]
        }
      }
    },
    {
      "name": "Buscar paciente",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{access_token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/superuser/patients?identifier=CC|1234567890",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "superuser", "patients"],
          "query": [{"key": "identifier", "value": "CC|1234567890"}]
        }
      }
    },
    {
      "name": "Crear paciente",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "Bearer {{access_token}}"},
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resourceType\": \"Patient\",\n  \"identifier\": [{\n    \"use\": \"official\",\n    \"type\": { \"coding\": [{ \"system\": \"http://terminology.hl7.org/CodeSystem/v2-0203\", \"code\": \"NI\" }] },\n    \"system\": \"https://www.registraduria.gov.co/cedula\",\n    \"value\": \"1234567890\"\n  }],\n  \"name\": [{ \"family\": \"García Martínez\", \"given\": [\"Carlos\", \"Eduardo\"] }],\n  \"gender\": \"male\",\n  \"birthDate\": \"1985-03-15\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/superuser/patients",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "superuser", "patients"]
        }
      }
    },
    {
      "name": "Obtener observaciones",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{access_token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/superuser/patients/{{patient_id}}/observations?loinc_code=2345-7&_count=50",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "superuser", "patients", "{{patient_id}}", "observations"],
          "query": [
            {"key": "loinc_code", "value": "2345-7"},
            {"key": "_count", "value": "50"}
          ]
        }
      }
    },
    {
      "name": "Registrar observación",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "Bearer {{access_token}}"},
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resourceType\": \"Observation\",\n  \"status\": \"final\",\n  \"code\": {\n    \"coding\": [{ \"system\": \"http://loinc.org\", \"code\": \"2345-7\", \"display\": \"Glucose [Mass/volume] in Blood\" }]\n  },\n  \"valueQuantity\": { \"value\": 130, \"unit\": \"mg/dL\" },\n  \"subject\": { \"reference\": \"Patient/{{patient_id}}\" }\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/superuser/patients/{{patient_id}}/observations",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "superuser", "patients", "{{patient_id}}", "observations"]
        }
      }
    }
  ],
  "variable": [
    {"key": "base_url", "value": "https://tu-dominio.com"},
    {"key": "access_token", "value": ""},
    {"key": "patient_id", "value": ""}
  ]
}
